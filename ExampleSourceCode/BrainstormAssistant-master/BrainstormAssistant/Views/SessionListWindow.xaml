<Window x:Class="BrainstormAssistant.Views.SessionListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Session" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" ResizeMode="NoResize">

    <Window.Resources>
        <local:SessionTimestampConverter x:Key="TimestampConverter" 
                                         xmlns:local="clr-namespace:BrainstormAssistant.Views"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select a session to load:" Foreground="#E0E0E0" 
                   FontSize="14" Margin="0,0,0,12"/>

        <ListBox Grid.Row="1" x:Name="SessionList" Background="#2D2D2D" Foreground="#E0E0E0"
                 BorderBrush="#555" BorderThickness="1"
                 MouseDoubleClick="SessionList_DoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding Title}" Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Foreground="#888888" FontSize="11">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} messages | {1}">
                                    <Binding Path="Messages.Count"/>
                                    <Binding Path="UpdatedAt" Converter="{StaticResource TimestampConverter}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Delete" Click="Delete_Click" Background="#8B0000" Foreground="White"
                    Padding="16,8" Margin="0,0,8,0" BorderBrush="#AA0000" BorderThickness="1" Cursor="Hand"/>
            <Button Content="Cancel" Click="Cancel_Click" Background="#3A3A3A" Foreground="#E0E0E0"
                    Padding="16,8" Margin="0,0,8,0" BorderBrush="#555" BorderThickness="1" Cursor="Hand"/>
            <Button Content="Load" Click="Load_Click" Background="#0078D4" Foreground="White"
                    Padding="16,8" BorderBrush="#0078D4" BorderThickness="1" Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>

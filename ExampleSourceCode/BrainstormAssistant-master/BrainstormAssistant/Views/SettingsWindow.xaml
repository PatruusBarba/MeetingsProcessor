<Window x:Class="BrainstormAssistant.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="800" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" ResizeMode="NoResize">

    <Window.Resources>
        <!-- Dark toggle button for ComboBox -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#3A3A3A"
                        BorderBrush="#555" BorderThickness="1" CornerRadius="2"/>
                <Border Grid.Column="0" Background="Transparent" Margin="1"/>
                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M0,0 L4,4 8,0" Stroke="#AAAAAA" StrokeThickness="1.5"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#0078D4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Dark ComboBox style with dark dropdown popup -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,6,28,6" VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200"
                                      SnapsToDevicePixels="True">
                                    <Border Background="#2D2D2D" BorderBrush="#555" BorderThickness="1"
                                            CornerRadius="2">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0063B1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="LLM Settings" Foreground="#E0E0E0" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Provider" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,4"/>
            <ComboBox x:Name="ProviderCombo" Background="#3A3A3A" Foreground="#E0E0E0" Padding="8,6"
                      BorderBrush="#555">
                <ComboBoxItem Content="openrouter" IsSelected="True"/>
                <ComboBoxItem Content="openai"/>
                <ComboBoxItem Content="custom"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="API Key" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ApiKeyBox" Background="#3A3A3A" Foreground="#E0E0E0" Padding="8,6"
                         BorderBrush="#555" PasswordChar="*"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <TextBlock Text="Model" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="ModelBox" Background="#3A3A3A" Foreground="#E0E0E0" Padding="8,6"
                     BorderBrush="#555" CaretBrush="White"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="Base URL (required for 'custom'; e.g. http://localhost:1234/v1)" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="BaseUrlBox" Background="#3A3A3A" Foreground="#E0E0E0" Padding="8,6"
                     BorderBrush="#555" CaretBrush="White"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,8">
            <TextBlock Text="Max Tokens (response length limit)" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="MaxTokensBox" Background="#3A3A3A" Foreground="#E0E0E0" Padding="8,6"
                     BorderBrush="#555" CaretBrush="White"/>
        </StackPanel>

        <TextBlock Grid.Row="6" Text="Voice Settings" Foreground="#E0E0E0" FontSize="16" FontWeight="Bold" Margin="0,12,0,12"/>

        <StackPanel Grid.Row="7" Margin="0,0,0,8">
            <TextBlock Text="TTS Voice Name (optional, uses system default)" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="TtsVoiceBox" Background="#3A3A3A" Foreground="#E0E0E0" Padding="8,6"
                     BorderBrush="#555" CaretBrush="White"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox x:Name="TtsEnabledCheck" Content="TTS Enabled" Foreground="#E0E0E0" 
                      VerticalContentAlignment="Center" Margin="0,0,20,0"/>
            <CheckBox x:Name="SttEnabledCheck" Content="STT Enabled" Foreground="#E0E0E0" 
                      VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="9" Margin="0,0,0,8">
            <TextBlock Text="Microphone" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,4"/>
            <ComboBox x:Name="MicCombo" Background="#3A3A3A" Foreground="#E0E0E0" Padding="8,6"
                      BorderBrush="#555"/>
        </StackPanel>

        <StackPanel Grid.Row="10" Margin="0,8,0,8">
            <TextBlock Text="Speech-to-Text Model" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,4"/>
            <DockPanel>
                <Button x:Name="DeleteModelBtn" Content="Delete Model" Click="DeleteModel_Click"
                        DockPanel.Dock="Right" Background="#C42B1C" Foreground="White"
                        Padding="12,6" Margin="8,0,0,0" BorderBrush="#C42B1C" BorderThickness="1"
                        Cursor="Hand" VerticalAlignment="Center"/>
                <TextBlock x:Name="SttModelStatus" Foreground="#AAAAAA" FontSize="12"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </DockPanel>
        </StackPanel>

        <TextBlock Grid.Row="11" Text="Available Models (for AI switching)" Foreground="#E0E0E0" FontSize="14" FontWeight="Bold" Margin="0,8,0,4"/>

        <StackPanel Grid.Row="12">
            <TextBlock Text="One model per line. AI selects by number ID." Foreground="#888888" FontSize="11" Margin="0,0,0,4"/>
            <TextBox x:Name="ModelListBox" Background="#3A3A3A" Foreground="#E0E0E0" Padding="8,6"
                     BorderBrush="#555" CaretBrush="White" AcceptsReturn="True" TextWrapping="Wrap"
                     Height="100" VerticalScrollBarVisibility="Auto" FontSize="12"/>
        </StackPanel>

        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Background="#3A3A3A" Foreground="#E0E0E0"
                    Padding="20,8" Margin="0,0,8,0" BorderBrush="#555" BorderThickness="1" Cursor="Hand"/>
            <Button Content="Save" Click="Save_Click" Background="#0078D4" Foreground="White"
                    Padding="20,8" BorderBrush="#0078D4" BorderThickness="1" Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>

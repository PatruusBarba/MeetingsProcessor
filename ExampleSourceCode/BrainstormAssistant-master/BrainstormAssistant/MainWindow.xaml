<Window x:Class="BrainstormAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:conv="clr-namespace:BrainstormAssistant.Converters"
        mc:Ignorable="d"
        Title="Brainstorm Assistant" Height="750" Width="1300"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <conv:RoleToAlignmentConverter x:Key="RoleToAlignment"/>
        <conv:RoleToColorConverter x:Key="RoleToColor"/>
        <conv:RoleToForegroundConverter x:Key="RoleToForeground"/>
        <conv:RoleToLabelConverter x:Key="RoleToLabel"/>
        <conv:TimestampToTimeConverter x:Key="TimestampToTime"/>
        <conv:BoolToMicTextConverter x:Key="BoolToMicText"/>
        <conv:RoleToMarginConverter x:Key="RoleToMargin"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:MicButtonColorConverter x:Key="MicButtonColor"/>

        <!-- Dark ToggleButton style -->
        <Style TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}" CornerRadius="2"
                                SnapsToDevicePixels="True"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="Bd" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock Text="Brainstorm Assistant" Foreground="#E0E0E0" 
                               FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding SessionTitle}" Foreground="#888888" 
                               FontSize="12" VerticalAlignment="Center" FontStyle="Italic"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="New" Click="NewSession_Click"
                            Background="#3A3A3A" Foreground="#E0E0E0" Padding="10,5" Margin="3,0"
                            BorderBrush="#555" BorderThickness="1" Cursor="Hand" FontSize="12"/>
                    <Button Content="Load" Click="LoadSession_Click"
                            Background="#3A3A3A" Foreground="#E0E0E0" Padding="10,5" Margin="3,0"
                            BorderBrush="#555" BorderThickness="1" Cursor="Hand" FontSize="12"/>
                    <Button Content="Save" Click="SaveSession_Click"
                            Background="#3A3A3A" Foreground="#E0E0E0" Padding="10,5" Margin="3,0"
                            BorderBrush="#555" BorderThickness="1" Cursor="Hand" FontSize="12"/>
                    <Button Content="Export" Click="ExportSession_Click"
                            Background="#3A3A3A" Foreground="#E0E0E0" Padding="10,5" Margin="3,0"
                            BorderBrush="#555" BorderThickness="1" Cursor="Hand" FontSize="12"/>
                    <Rectangle Width="1" Fill="#555" Margin="4,2"/>
                    <Button Content="Summary" Click="Summary_Click"
                            Background="#2E5A2E" Foreground="White" Padding="10,5" Margin="3,0"
                            BorderBrush="#3A7A3A" BorderThickness="1" Cursor="Hand" FontSize="12"/>
                    <Button Content="Evaluate" Click="Evaluate_Click"
                            Background="#8B5E00" Foreground="White" Padding="10,5" Margin="3,0"
                            BorderBrush="#AA7700" BorderThickness="1" Cursor="Hand" FontSize="12"/>
                    <Button Content="Biz Plan" Click="BusinessPlan_Click"
                            Background="#5E3A8B" Foreground="White" Padding="10,5" Margin="3,0"
                            BorderBrush="#7A4AAA" BorderThickness="1" Cursor="Hand" FontSize="12"/>
                    <Button Content="Spec/PRD" Click="Spec_Click"
                            Background="#3A5E8B" Foreground="White" Padding="10,5" Margin="3,0"
                            BorderBrush="#4A7AAA" BorderThickness="1" Cursor="Hand" FontSize="12"/>
                    <Rectangle Width="1" Fill="#555" Margin="4,2"/>
                    <ToggleButton x:Name="ServerToggle" Content="Server"
                            Background="#3A3A3A" Foreground="#E0E0E0" Padding="10,5" Margin="3,0"
                            BorderBrush="#555" BorderThickness="1" Cursor="Hand" FontSize="12"
                            Checked="ServerToggle_Changed" Unchecked="ServerToggle_Changed"/>
                    <Button Content="Settings" Click="Settings_Click"
                            Background="#3A3A3A" Foreground="#E0E0E0" Padding="10,5" Margin="3,0"
                            BorderBrush="#555" BorderThickness="1" Cursor="Hand" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content: Chat + Boards side by side -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="350"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="BoardColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Chat messages area -->
            <ScrollViewer Grid.Column="0" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto"
                          Background="#1E1E1E" Padding="8">
                <ItemsControl x:Name="ChatItemsControl" ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Role, Converter={StaticResource RoleToColor}}"
                                    CornerRadius="12"
                                    Padding="12,8"
                                    Margin="{Binding Role, Converter={StaticResource RoleToMargin}}"
                                    HorizontalAlignment="{Binding Role, Converter={StaticResource RoleToAlignment}}"
                                    MaxWidth="600">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Role, Converter={StaticResource RoleToLabel}}"
                                                   Foreground="#AAAAAA" FontSize="11" FontWeight="SemiBold"
                                                   DockPanel.Dock="Left"/>
                                        <TextBlock Text="{Binding Timestamp, Converter={StaticResource TimestampToTime}}"
                                                   Foreground="#888888" FontSize="10" HorizontalAlignment="Right"
                                                   DockPanel.Dock="Right"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                               Foreground="{Binding Role, Converter={StaticResource RoleToForeground}}"
                                               FontSize="14" LineHeight="20"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="#333"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Visibility="{Binding BoardVisible, Converter={StaticResource StringToVisibility}}"/>

            <!-- Board panel (MD + HTML tabs) -->
            <Border Grid.Column="2" Background="#1A1A1A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Board tab header -->
                    <Border Grid.Row="0" Background="#2D2D2D" Padding="6">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <RadioButton x:Name="MdTabButton" Content="Markdown" 
                                             GroupName="BoardTab" IsChecked="True"
                                             Foreground="#E0E0E0" Margin="0,0,8,0"
                                             Checked="BoardTab_Changed" FontSize="12"/>
                                <RadioButton x:Name="HtmlTabButton" Content="HTML" 
                                             GroupName="BoardTab"
                                             Foreground="#E0E0E0" Margin="0,0,8,0"
                                             Checked="BoardTab_Changed" FontSize="12"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Save" Click="SaveArtifact_Click"
                                        Background="#3A3A3A" Foreground="#E0E0E0" Padding="8,3" Margin="3,0"
                                        BorderBrush="#555" BorderThickness="1" Cursor="Hand" FontSize="11"/>
                                <Button Content="Close" Click="CloseBoard_Click"
                                        Background="#5A2A2A" Foreground="#E0E0E0" Padding="8,3" Margin="3,0"
                                        BorderBrush="#7A3A3A" BorderThickness="1" Cursor="Hand" FontSize="11"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- WebView2 for rendering MD and HTML with full JS support -->
                    <wv2:WebView2 Grid.Row="1" x:Name="BoardBrowser" DefaultBackgroundColor="#1E1E1E"/>

                    <!-- Board status -->
                    <Border Grid.Row="2" Background="#252525" Padding="4">
                        <TextBlock x:Name="BoardStatusText" Text="Board ready" 
                                   Foreground="#888888" FontSize="10"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Partial speech indicator -->
        <Border Grid.Row="2" Background="#252525" Padding="8,4"
                Visibility="{Binding PartialSpeech, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding PartialSpeech}" Foreground="#888888" FontStyle="Italic" FontSize="12"/>
        </Border>

        <!-- Input area -->
        <Border Grid.Row="3" Background="#2D2D2D" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="{Binding IsListening, Converter={StaticResource BoolToMicText}}"
                        Click="ToggleVoice_Click"
                        Background="{Binding IsListening, Converter={StaticResource MicButtonColor}}"
                        Foreground="White" Padding="12,8" Margin="0,0,8,0"
                        BorderBrush="#555" BorderThickness="1" Cursor="Hand"
                        FontSize="14"/>

                <TextBox Grid.Column="1" x:Name="InputTextBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3A3A3A" Foreground="#E0E0E0" 
                         CaretBrush="White" FontSize="14"
                         Padding="10,8" BorderBrush="#555" BorderThickness="1"
                         VerticalContentAlignment="Center"
                         KeyDown="InputTextBox_KeyDown"
                         AcceptsReturn="False"/>

                <Button Grid.Column="2" Content="Send" Click="Send_Click"
                        Background="#0078D4" Foreground="White" Padding="16,8" Margin="8,0,0,0"
                        BorderBrush="#0078D4" BorderThickness="1" Cursor="Hand"
                        FontSize="14" FontWeight="SemiBold"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>

                <ToggleButton Grid.Column="3" x:Name="TtsToggle" Content="TTS" 
                              Margin="8,0,0,0" Padding="10,8"
                              Background="#3A3A3A" Foreground="#E0E0E0"
                              BorderBrush="#555" BorderThickness="1" Cursor="Hand"
                              FontSize="14" Checked="TtsToggle_Changed" Unchecked="TtsToggle_Changed"
                              IsChecked="True"/>

                <Button Grid.Column="4" x:Name="StopTtsButton" Content="⏹ Stop" 
                        Click="StopTts_Click"
                        Margin="8,0,0,0" Padding="10,8"
                        Background="#8B2222" Foreground="White"
                        BorderBrush="#AA3333" BorderThickness="1" Cursor="Hand"
                        FontSize="14" Visibility="Collapsed"/>

                <ToggleButton Grid.Column="5" x:Name="BoardToggle" Content="Board" 
                              Margin="8,0,0,0" Padding="10,8"
                              Background="#3A3A3A" Foreground="#E0E0E0"
                              BorderBrush="#555" BorderThickness="1" Cursor="Hand"
                              FontSize="14" Checked="BoardToggle_Changed" Unchecked="BoardToggle_Changed"/>
            </Grid>
        </Border>

        <!-- Download progress bar (hidden by default) -->
        <Grid Grid.Row="4" x:Name="DownloadProgressPanel" Visibility="Collapsed" Background="#252525">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="DownloadFileText" Grid.Column="0" Foreground="#B0B0B0" FontSize="11" 
                       VerticalAlignment="Center" Margin="8,4"/>
            <ProgressBar x:Name="DownloadProgressBar" Grid.Column="1" Height="14" Margin="4,4"
                         Minimum="0" Maximum="100" Value="0"
                         Foreground="#0078D4" Background="#3A3A3A" BorderBrush="#555" BorderThickness="1"/>
            <TextBlock x:Name="DownloadPercentText" Grid.Column="2" Foreground="#B0B0B0" FontSize="11"
                       VerticalAlignment="Center" Margin="4,4,8,4" MinWidth="40" TextAlignment="Right"/>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="5" Background="#007ACC" Padding="6,3">
            <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11"/>
        </Border>
    </Grid>
</Window>

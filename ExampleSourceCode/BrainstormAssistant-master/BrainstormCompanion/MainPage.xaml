<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BrainstormCompanion.MainPage"
             BackgroundColor="#1E1E1E"
             Title="Brainstorm Companion">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection status -->
        <Frame Grid.Row="0" BackgroundColor="#2D2D2D" CornerRadius="8" Padding="10" HasShadow="False">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <HorizontalStackLayout Spacing="8">
                    <Label x:Name="StatusDot" Text="●" TextColor="Red" FontSize="14" VerticalOptions="Center"/>
                    <Label x:Name="StatusLabel" Text="Not connected" TextColor="#AAAAAA" FontSize="13" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>
        </Frame>

        <!-- Server address input -->
        <Frame Grid.Row="1" BackgroundColor="#2D2D2D" CornerRadius="8" Padding="10" HasShadow="False">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Entry x:Name="ServerEntry" Placeholder="Server (e.g. 192.168.1.100:5225)"
                       PlaceholderColor="#666666" TextColor="#E0E0E0" BackgroundColor="#3A3A3A"
                       FontSize="13"/>
                <Button Grid.Column="1" x:Name="ConnectButton" Text="Connect" 
                        BackgroundColor="#0078D4" TextColor="White" FontSize="13"
                        Clicked="OnConnectClicked"/>
            </Grid>
        </Frame>

        <!-- Board WebView (always visible) -->
        <Frame Grid.Row="2" BackgroundColor="#1A1A1A" CornerRadius="8" Padding="0" HasShadow="False">
            <WebView x:Name="BoardWebView">
                <WebView.Source>
                    <HtmlWebViewSource Html="&lt;!DOCTYPE html&gt;&lt;html&gt;&lt;body style='background:#1e1e1e;color:#666;font-family:sans-serif;display:flex;align-items:center;justify-content:center;height:90vh;margin:0'&gt;&lt;p&gt;Board will appear here...&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;"/>
                </WebView.Source>
            </WebView>
        </Frame>

        <!-- Transcription + response -->
        <Frame Grid.Row="3" BackgroundColor="#2D2D2D" CornerRadius="8" Padding="10" HasShadow="False"
               HeightRequest="80">
            <ScrollView>
                <StackLayout Spacing="4">
                    <Label x:Name="TranscriptionLabel" Text="" TextColor="#888888" 
                           FontSize="11" FontAttributes="Italic"/>
                    <Label x:Name="ResponseLabel" Text="Speak to start..."
                           TextColor="#E0E0E0" FontSize="13" LineBreakMode="WordWrap"/>
                </StackLayout>
            </ScrollView>
        </Frame>

        <!-- Push-to-Talk button + Stop TTS -->
        <Grid Grid.Row="4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="PttButton" Text="🎤  Hold to Talk" 
                    BackgroundColor="#3A3A3A" TextColor="White" 
                    FontSize="20" HeightRequest="80" CornerRadius="16"
                    Pressed="OnPttPressed" Released="OnPttReleased"
                    IsEnabled="False"/>
            <Button Grid.Column="1" x:Name="StopTtsButton" Text="⏹"
                    BackgroundColor="#8B2222" TextColor="White"
                    FontSize="20" HeightRequest="80" WidthRequest="80" CornerRadius="16"
                    Clicked="OnStopTtsClicked"
                    IsVisible="False"/>
        </Grid>

        <!-- Bottom toolbar: Audio device + Refresh + VAD toggle -->
        <Grid Grid.Row="5" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Picker x:Name="AudioDevicePicker" Title="📱 Audio Device"
                    BackgroundColor="#2D2D2D" TextColor="#E0E0E0" TitleColor="#888888"
                    FontSize="13" HeightRequest="44"
                    SelectedIndexChanged="OnAudioDeviceChanged"/>
            <Button Grid.Column="1" Text="🔄" BackgroundColor="#2D2D2D" TextColor="#E0E0E0"
                    FontSize="16" HeightRequest="44" WidthRequest="44" CornerRadius="8"
                    Clicked="OnRefreshDevicesClicked"/>
            <Button Grid.Column="2" x:Name="HandsFreeButton" Text="🙌  Hands-Free: OFF"
                    BackgroundColor="#2D2D2D" TextColor="#AAAAAA" FontSize="14"
                    CornerRadius="8" HeightRequest="44"
                    Clicked="OnHandsFreeClicked" IsEnabled="False"/>
        </Grid>
    </Grid>
</ContentPage>
